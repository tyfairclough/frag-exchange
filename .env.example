# Copy to `.env` locally (never commit real secrets).
# Hostinger: set the same keys in the Node.js app environment panel.

# --- MySQL only ---
# This app uses Prisma with `datasource provider = "mysql"` and the MariaDB driver.
# Do not use PostgreSQL, `postgresql://`, `postgres://`, or `prisma+postgres://` URLs.

# MySQL connection (Prisma). Example:
# mysql://USER:PASSWORD@HOST:3306/DATABASE?connection_limit=5
DATABASE_URL="mysql://user:password@127.0.0.1:3306/frag_exchange"

# Magic link email (optional — Mailtrap). Without MAILTRAP_API_KEY + EMAIL_FROM, sign-in still works via the dev debug link on /auth/check-email.
# Create a token at https://mailtrap.io/api-tokens — production sending needs a verified domain on Mailtrap.
# MAILTRAP_API_KEY="..."
# EMAIL_FROM="Frag Exchange <noreply@yourdomain.com>"
# Optional: capture mail in Mailtrap Email Sandbox instead of delivering (set inbox ID from your sandbox inbox URL).
# MAILTRAP_USE_SANDBOX="true"
# MAILTRAP_INBOX_ID="1234567"

# Public site URL for links inside emails (recommended on Hostinger).
# NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# Optional: NODE_ENV is usually set by the host (production).
