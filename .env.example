# Copy to `.env` for optional local secrets (Mailtrap, etc.). Never commit real secrets.
# Hostinger: set DATABASE_URL, NEXT_PUBLIC_APP_URL, and email keys in the Node.js environment panel.

# --- Neon Postgres / DATABASE_URL ---
# Local `npm run dev`: copy the dev block below into `.env.development` (Docker Postgres after `npm run db:up`).
# Do not set DATABASE_URL here unless you need to override local Docker (e.g. remote DB while debugging).
#
# Production (`next build` / `next start` on Hostinger): DATABASE_URL must be set in the hosting
# panel only — it is not loaded from `.env.development` when NODE_ENV=production.
#
# Hostinger production: DATABASE_URL should be the Neon pooled URL.
# DIRECT_URL should be the direct Neon URL for Prisma migrate/introspection.
#
# Local dev server port is **3111** (avoids 3000 and 3001–3010). Change in `package.json` `dev` and `.env.development` `PORT` together.
#
# Local Prisma Migrate `dev` does not need PRISMA_SHADOW_DATABASE_URL for Postgres.

# This app uses Prisma with `datasource provider = "postgresql"`.
# Use Neon pooled and direct Postgres URLs.

# Magic link email (optional — Mailtrap). Without MAILTRAP_API_KEY + EMAIL_FROM, sign-in still works via the debug link on /auth/check-email when running `next dev` (NODE_ENV=development) only.
# Create a token at https://mailtrap.io/api-tokens — production sending needs a verified domain on Mailtrap.
# MAILTRAP_API_KEY="..."
# EMAIL_FROM="REEFX <noreply@reefx.net>"
# Optional: capture mail in Mailtrap Email Sandbox instead of delivering (set inbox ID from your sandbox inbox URL).
# MAILTRAP_USE_SANDBOX="true"
# MAILTRAP_INBOX_ID="1234567"

# Public site URL for links inside emails (recommended on Hostinger).
# NEXT_PUBLIC_APP_URL="https://reefx.net"

# Chunk 4 — comma-separated emails treated as super admins (can create exchanges). Optional if you set users.globalRole in the database.
# REEFX_SUPER_ADMIN_EMAILS="you@example.com,other@example.com"

# Bootstrap the first super admin (password sign-in) when the DB has no SUPER_ADMIN yet. Seed command is set in prisma.config.ts — run from `web/`: npx prisma db seed
# REEFX_BOOTSTRAP_ADMIN_EMAIL="ty.fairclough@gmail.com"
# REEFX_BOOTSTRAP_ADMIN_PASSWORD="your-local-password-only"

# Optional: NODE_ENV is usually set by the host (production).

# Chunk 10 — cron / housekeeping (listing cleanup + global trade expiry). Protect the URL with a long random secret.
# Hostinger: schedule GET or POST to https://yourdomain.com/api/cron/housekeeping?secret=... or use Authorization: Bearer ...
# CRON_SECRET="..."

# Optional server-only base URL for cron when NEXT_PUBLIC_APP_URL is unset (e.g. internal hostname).
# APP_BASE_URL="https://reefx.net"

# Chunk 9 — second notification channel (JSON POST). When email is off or fails, or user prefers SMS (no SMS provider wired yet), events still post here.
# Optional shared secret header: x-reefx-notify-secret
# NOTIFY_WEBHOOK_URL="https://your-automation.example/hooks/reefx"
# NOTIFY_WEBHOOK_SECRET="..."

# Coral AI enrichment (Chunk 3): without OPENAI_API_KEY, "Suggest fields (AI)" uses offline starter text.
# Add coral → Submit (photo) uses the same key for vision; use a vision-capable model (e.g. gpt-4o-mini).
# OPENAI_API_KEY="sk-..."
# Optional override for the chat model (default gpt-4o-mini).
# CORAL_AI_MODEL="gpt-4o-mini"

# Ideal Postcodes address finder (server-side; keep secret).
# Used by `web/src/app/api/ideal-postcodes/*` proxy routes.
# REEFX_IDEAL_POSTCODES_API_KEY should typically begin with `ak_`.
REEFX_IDEAL_POSTCODES_API_KEY="ak_..."

# Optional override for Nominatim User-Agent (must identify your app; default is REEFX/0.1 with support@reefx.net).
# REEFX_NOMINATIM_USER_AGENT="..."


# Loaded automatically when running `npm run dev` (NODE_ENV=development).
# Docker Postgres — from web/: `npm run db:up` then `npm run db:migrate:dev`
# Do not put production or Hostinger secrets here.

# Dev server port (avoid 3000–3010). Keep in sync with package.json `dev` script `-p`.
PORT=3111
DATABASE_URL=postgresql://frag:fraglocaldev@localhost:5432/frag_exchange?sslmode=disable
# Neon direct URL for prisma migrate/introspection (local can mirror DATABASE_URL).
DIRECT_URL=postgresql://frag:fraglocaldev@localhost:5432/frag_exchange?sslmode=disable
NODE_ENV=development

#mailtrap credentials
MAILTRAP_USE_SANDBOX=true
MAILTRAP_API_KEY=key_1234567890
MAILTRAP_INBOX_ID=123456
EMAIL_FROM=email@example.com

#coral ai credentials
CORAL_AI_MODEL=ai_model_1234567890
OPENAI_API_KEY=sk-proj-1234567890
REEFX_IDEAL_POSTCODES_API_KEY=ak_

#super admin credentials
REEFX_SUPER_ADMIN_EMAILS=email@example.com
REEFX_BOOTSTRAP_ADMIN_PASSWORD=$1234567890
