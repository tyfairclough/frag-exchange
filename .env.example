# Copy to `.env` locally (never commit real secrets).
# Hostinger: set the same keys in the Node.js app environment panel.

# --- MySQL only ---
# This app uses Prisma with `datasource provider = "mysql"` and the MariaDB driver.
# Do not use PostgreSQL, `postgresql://`, `postgres://`, or `prisma+postgres://` URLs.

# MySQL connection (Prisma). Example:
# mysql://USER:PASSWORD@HOST:3306/DATABASE?connection_limit=5
DATABASE_URL="mysql://user:password@127.0.0.1:3306/frag_exchange"

# Optional: NODE_ENV is usually set by the host (production).
