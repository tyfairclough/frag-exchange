// REEFX — Prisma schema (PostgreSQL on Neon / Hostinger)
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Baseline user row for upcoming auth/profile (Chunk 2). Extend as needed.
model User {
  id                        String               @id @default(cuid())
  email                     String               @unique @db.VarChar(255)
  alias                     String?              @db.VarChar(80)
  avatarEmoji              String?              @db.VarChar(12)
  tosAcceptedAt             DateTime?
  tosVersion                String?              @db.VarChar(40)
  privacyAcceptedAt         DateTime?
  privacyVersion            String?              @db.VarChar(40)
  contactPreference         ContactPreference    @default(EMAIL)
  onboardingPath            OnboardingPath?
  onboardingCompletedAt     DateTime?
  /// Platform operators who can create exchanges and assign event managers.
  globalRole                UserGlobalRole       @default(MEMBER)
  /// Super-admin-assigned tier for future commercial posting tools (LFS vs online retailer).
  postingRole               UserPostingRole?
  /// Bcrypt hash for optional password sign-in (magic link remains supported when null).
  passwordHash              String?              @db.VarChar(255)
  /// Free text: kinds of items the user wants to trade (profiles / recommendations later).
  tradeSeekingNotes         String?              @db.Text
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  address                   UserAddress?
  sessions                  Session[]
  magicLinkRequests         MagicLinkToken[]
  inventoryItems            InventoryItem[]
  exchangesCreated          Exchange[]           @relation("ExchangeCreatedBy")
  exchangeMemberships       ExchangeMembership[]
  exchangeInvitesSent       ExchangeInvite[]     @relation("ExchangeInviteInvitedBy")
  tradesInitiated           Trade[]              @relation("TradeInitiator")
  tradesAsPeer              Trade[]              @relation("TradePeer")
  adminAuditLogs            AdminAuditLog[]
  inventoryImportJobs       InventoryImportJob[]
  inventoryImportCandidates InventoryImportCandidate[]

  @@map("users")
}

/// Chunk 10 — super-admin platform actions (exchange CRUD, demotions, etc.).
model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String   @db.VarChar(120)
  targetType  String?  @db.VarChar(80)
  targetId    String?  @db.VarChar(40)
  metadata    Json?
  ip          String?  @db.VarChar(80)
  createdAt   DateTime @default(now())
  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId, createdAt])
  @@map("admin_audit_logs")
}

/// Words used to build default onboarding aliases (super-admin CRUD).
model AliasGeneratorWord {
  id        String   @id @default(cuid())
  word      String   @unique @db.VarChar(64)
  createdAt DateTime @default(now())

  @@map("alias_generator_words")
}

/// Chunk 4 — exchange hub: event vs group, public vs private, membership + invites.
model Exchange {
  id          String             @id @default(cuid())
  name        String             @db.VarChar(160)
  description String?            @db.Text
  allowCoral  Boolean            @default(true)
  allowFish   Boolean            @default(true)
  allowEquipment Boolean         @default(true)
  allowItemsForSale Boolean      @default(false)
  logo40Url   String?            @db.VarChar(2048)
  logo80Url   String?            @db.VarChar(2048)
  logo512Url  String?            @db.VarChar(2048)
  logoUpdatedAt DateTime?
  kind        ExchangeKind
  visibility  ExchangeVisibility
  /// For event exchanges; used later for trade expiry (Chunk 6).
  eventDate   DateTime?
  createdById String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  createdBy   User               @relation("ExchangeCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  memberships ExchangeMembership[]
  invites     ExchangeInvite[]
  listings    ExchangeListing[]
  trades      Trade[]

  @@index([visibility, kind])
  @@map("exchanges")
}

model ExchangeMembership {
  id          String                   @id @default(cuid())
  exchangeId  String
  userId      String
  role        ExchangeMembershipRole     @default(MEMBER)
  joinedAt    DateTime                 @default(now())
  exchange    Exchange                 @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([exchangeId, userId])
  @@index([userId])
  @@map("exchange_memberships")
}

model ExchangeInvite {
  id          String    @id @default(cuid())
  exchangeId  String
  email       String    @db.VarChar(255)
  tokenHash   String    @unique @db.VarChar(64)
  expiresAt   DateTime
  usedAt      DateTime?
  /// Last time the invite link was emailed (initial send or resend); falls back to createdAt in UI when null.
  lastSentAt  DateTime?
  invitedById String
  createdAt   DateTime  @default(now())
  exchange    Exchange  @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("ExchangeInviteInvitedBy", fields: [invitedById], references: [id], onDelete: Restrict)

  @@index([exchangeId, email])
  @@map("exchange_invites")
}

/// A profile item (coral, fish, equipment) listed on a specific exchange.
model ExchangeListing {
  id               String         @id @default(cuid())
  exchangeId       String
  inventoryItemId  String
  listedAt         DateTime       @default(now())
  expiresAt        DateTime
  exchange         Exchange       @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  inventoryItem    InventoryItem  @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([exchangeId, inventoryItemId])
  @@index([exchangeId, expiresAt])
  @@map("exchange_listings")
}

enum UserGlobalRole {
  MEMBER
  SUPER_ADMIN
}

enum UserPostingRole {
  LFS
  ONLINE_RETAILER
}

enum ExchangeKind {
  EVENT
  GROUP
}

enum ExchangeVisibility {
  PUBLIC
  PRIVATE
}

enum ExchangeMembershipRole {
  MEMBER
  EVENT_MANAGER
}

enum InventoryKind {
  CORAL
  FISH
  EQUIPMENT
}

enum EquipmentCategory {
  LIGHTS
  PUMPS
  MONITORS_CONTROLLERS
  FILTRATION
  DOSING
  OTHER
}

enum EquipmentCondition {
  LIKE_NEW
  GOOD_CONDITION
  WORKING
  SPARES_REPAIRS
}

/// Profile-level inventory: corals, fish, and equipment. Listed on exchanges until traded.
model InventoryItem {
  id             String             @id @default(cuid())
  userId         String
  kind           InventoryKind
  name           String             @db.VarChar(120)
  description    String             @db.Text
  imageUrl       String?            @db.VarChar(2048)
  listingMode    CoralListingMode   @default(BOTH)
  listingIntent  ListingIntent      @default(SWAP)
  salePriceMinor Int?
  saleCurrencyCode String?          @db.VarChar(3)
  saleExternalUrl String?           @db.VarChar(2048)
  profileStatus  CoralProfileStatus @default(UNLISTED)
  totalQuantity  Int                @default(1)
  remainingQuantity Int             @default(1)
  /// Coral taxonomy (when kind = CORAL).
  coralType      String?            @db.VarChar(120)
  /// Coral + fish colour palette (when kind = CORAL or FISH); empty for equipment.
  colours        String[]           @default([])
  /// Fish (when kind = FISH).
  species        String?            @db.VarChar(200)
  reefSafe       Boolean?
  /// Equipment (when kind = EQUIPMENT).
  equipmentCategory   EquipmentCategory?
  equipmentCondition EquipmentCondition?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchangeListings ExchangeListing[]
  tradeLines     TradeInventoryLine[]
  importCandidates InventoryImportCandidate[]

  @@index([userId])
  @@index([kind])
  @@map("inventory_items")
}

enum CoralListingMode {
  POST
  MEET
  BOTH
}

enum CoralProfileStatus {
  UNLISTED
  TRADED
}

enum ListingIntent {
  SWAP
  FREE
  FOR_SALE
}

enum InventoryImportJobStatus {
  QUEUED
  RUNNING
  REVIEW_READY
  COMPLETED
  FAILED
  CANCELLED
}

model InventoryImportJob {
  id               String                  @id @default(cuid())
  userId           String
  sourceUrl        String                  @db.VarChar(2048)
  sourceHost       String                  @db.VarChar(255)
  status           InventoryImportJobStatus @default(QUEUED)
  maxPages         Int                     @default(20)
  maxDepth         Int                     @default(2)
  crawlDelayMs     Int                     @default(250)
  pagesVisited     Int                     @default(0)
  pagesParsed      Int                     @default(0)
  candidatesFound  Int                     @default(0)
  candidatesReady  Int                     @default(0)
  candidatesFailed Int                     @default(0)
  runToken         String?                 @db.VarChar(64)
  runLeaseExpiresAt DateTime?
  attemptCount     Int                     @default(0)
  lastError        String?                 @db.Text
  startedAt        DateTime?
  finishedAt       DateTime?
  notifiedAt       DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidates       InventoryImportCandidate[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("inventory_import_jobs")
}

model InventoryImportCandidate {
  id                String         @id @default(cuid())
  jobId             String
  userId            String
  sourcePageUrl     String         @db.VarChar(2048)
  sourceHash        String         @db.VarChar(64)
  title             String?        @db.VarChar(240)
  snippet           String?        @db.Text
  kind              InventoryKind?
  confidenceScore   Float?
  name              String?        @db.VarChar(120)
  description       String?        @db.Text
  imageUrl          String?        @db.VarChar(2048)
  coralType         String?        @db.VarChar(120)
  colours           String[]       @default([])
  species           String?        @db.VarChar(200)
  reefSafe          Boolean?
  quantity          Int            @default(1)
  salePriceMinor    Int            @default(100)
  saleCurrencyCode  String         @default("GBP") @db.VarChar(3)
  saleExternalUrl   String         @db.VarChar(2048)
  selectedExchangeIds String[]     @default([])
  approvedAt        DateTime?
  rejectedAt        DateTime?
  createdItemId     String?
  validationError   String?        @db.Text
  parseError        String?        @db.Text
  aiRaw             Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  job               InventoryImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdItem       InventoryItem? @relation(fields: [createdItemId], references: [id], onDelete: SetNull)

  @@unique([jobId, sourceHash])
  @@index([userId, sourceHash])
  @@index([jobId, approvedAt])
  @@map("inventory_import_candidates")
}

/// Multi-item trade between two members on one exchange (any inventory kinds).
model Trade {
  id              String      @id @default(cuid())
  exchangeId      String
  initiatorUserId String
  peerUserId      String
  status          TradeStatus @default(OFFER)
  /// Incremented on counter and accept so concurrent accepts fail cleanly.
  version         Int         @default(0)
  expiresAt       DateTime
  /// Set when expiry notifications were sent (avoids duplicate emails on repeated page loads).
  expiredNotifiedAt DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  exchange        Exchange    @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  initiator       User        @relation("TradeInitiator", fields: [initiatorUserId], references: [id], onDelete: Restrict)
  peer            User        @relation("TradePeer", fields: [peerUserId], references: [id], onDelete: Restrict)
  inventoryLines  TradeInventoryLine[]

  @@index([exchangeId, status])
  @@index([initiatorUserId])
  @@index([peerUserId])
  @@map("trades")
}

model TradeInventoryLine {
  id                  String                       @id @default(cuid())
  tradeId             String
  inventoryItemId     String
  side                TradeLineSide
  /// Event-day desk flow: set when an approved trade is on an EVENT exchange; null for group swaps.
  eventHandoffStatus  TradeLineEventHandoffStatus?
  trade               Trade                        @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  inventoryItem       InventoryItem                @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@unique([tradeId, inventoryItemId])
  @@index([inventoryItemId])
  @@index([eventHandoffStatus])
  @@map("trade_inventory_lines")
}

enum TradeStatus {
  OFFER
  REJECTED
  COUNTERED
  APPROVED
  EXPIRED
}

enum TradeLineSide {
  INITIATOR
  PEER
}

/// Physical handoff at an event exchange after trade approval (Available → checked-in → checked-out).
enum TradeLineEventHandoffStatus {
  AWAITING_CHECKIN
  CHECKED_IN
  CHECKED_OUT
}

model UserAddress {
  id          String   @id @default(cuid())
  userId      String   @unique
  line1       String   @db.VarChar(255)
  line2       String?  @db.VarChar(255)
  town        String   @db.VarChar(120)
  region      String?  @db.VarChar(120)
  postalCode  String   @db.VarChar(40)
  countryCode String   @db.VarChar(2)
  /// Approximate town-centre coordinates for coarse distance (never exact home); geocoded once from town + country.
  townLatitude  Float?
  townLongitude Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_addresses")
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique @db.VarChar(64)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  revokedAt  DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("sessions")
}

model MagicLinkToken {
  id          String   @id @default(cuid())
  userId      String
  email       String   @db.VarChar(255)
  tokenHash   String   @unique @db.VarChar(64)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())
  requestedIp String?  @db.VarChar(80)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("magic_link_tokens")
}

enum ContactPreference {
  EMAIL
  SMS
}

enum OnboardingPath {
  EVENT_ONLY
  GROUP_AND_EVENT
}
